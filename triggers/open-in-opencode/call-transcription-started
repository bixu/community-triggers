#!/usr/bin/env bash
set -euo pipefail

LOG=/tmp/tuple-trigger-debug.log
{
    printf '\n=== %s call-transcription-started fired (open-in-opencode) ===\n' "$(date -u +%FT%TZ)"
    printf 'cwd=%s pid=%s ppid=%s\n' "$(pwd)" "$$" "$PPID"
    printf 'argv: %s\n' "$*"
    printf 'env (filtered):\n'
    env | grep -E '^(HOME|USER|PATH|TUPLE_|CURRENT_USER_)' | sort
} >> "$LOG" 2>&1
trap 'printf "exit status=%s on line %s\n" "$?" "$LINENO" >> "$LOG"' EXIT

exec >>"$LOG" 2>&1

if [ -z "${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY:-}" ]; then
    echo "open-in-opencode: TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY was not set" >&2
    exit 1
fi

TRANSCRIPTION_DIR="${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY}"
if [ ! -d "${TRANSCRIPTION_DIR}" ]; then
    echo "open-in-opencode: transcription directory does not exist: ${TRANSCRIPTION_DIR}" >&2
    exit 1
fi

SESSION_DIR="$(basename "${TRANSCRIPTION_DIR}")"
PARENT_DIR="$(dirname "${TRANSCRIPTION_DIR}")"
PARENT_NAME="$(basename "${PARENT_DIR}")"
if [[ "${SESSION_DIR}" == *"@"* ]]; then
    CALL_ID="${SESSION_DIR##*@}"
elif [[ "${PARENT_NAME}" =~ ^[0-9A-Fa-f-]{8,}$ ]]; then
    CALL_ID="${PARENT_NAME}"
else
    CALL_ID="${SESSION_DIR}"
fi

PID_FILE="${TRANSCRIPTION_DIR}/opencode-sidekick.pid"
PROMPT_FILE="${TRANSCRIPTION_DIR}/opencode-sidekick-prompt.md"
# Set your preferred terminal here, or leave empty to auto-detect.
# One of: ghostty | iterm | alacritty | terminal
# (Also overridable from the environment: PREFERRED_TERM=iterm)
PREFERRED_TERM="${PREFERRED_TERM:-}"
COMMAND_FILE="${TRANSCRIPTION_DIR}/open-in-opencode.sh"

if [ -f "${PID_FILE}" ] && kill -0 "$(cat "${PID_FILE}" 2>/dev/null)" 2>/dev/null; then
    echo "open-in-opencode: OpenCode sidekick already running for ${TRANSCRIPTION_DIR}"
    exit 0
fi

{
    cat <<'PROMPT'
You are a real-time companion on a live Tuple pair-programming call. Your working directory is the current Tuple transcription directory opened by this trigger.

PROMPT
    printf 'The trigger fired for:\n\n'
    printf -- '- Transcription directory: %s\n' "${TRANSCRIPTION_DIR}"
    printf -- '- Session directory name: %s\n' "${SESSION_DIR}"
    printf -- '- Inferred call id: %s\n' "${CALL_ID}"
    cat <<'PROMPT'

The current directory should contain `events.jsonl` and `transcriptions.jsonl`, one JSON record per line. Other call participants do not see your output; you interact only with the user at this terminal.

## Catch up first

Before choosing an observation strategy, read the current directory's `transcriptions.jsonl` and `events.jsonl` in full. A file-following loop only sees records appended after it starts, so this initial read is the only way to recover the call so far. If a file is missing because transcription has just started, say that briefly and continue.

## File schemas

| File | Fields | Notes |
| --- | --- | --- |
| `events.jsonl` | `category, message, time, user?` | Categories commonly include `recording_started`, `recording_stopped`, `user_joined`, `user_left`, `user_audio_started`, `user_audio_stopped`, and `call_ended`. |
| `transcriptions.jsonl` | `start, end, text, user_id` | Resolve `user_id` to a name from `user_joined` events when available. |

If a field looks unfamiliar, inspect a few records and adapt rather than assuming.

## Observation strategy

Stay responsive to the user. Do not run a long-lived command if it monopolizes your session, prevents you from seeing terminal input, or prevents you from replying. Pick the strongest observation strategy your OpenCode environment can support without blocking interaction.

Always treat `events.jsonl` and `transcriptions.jsonl` as the source of truth. Track a byte offset or last processed record for each file. If the parent directory contains sibling transcription directories for the same call, include directories whose names end with the inferred call id from the trigger header in the watch set. If no sibling layout is present, just observe the current directory.

Preferred behavior:

1. On startup, catch up from the beginning of the current files.
2. Before every response to the user, rescan candidate files, read forward from your saved offsets, and print any newly discovered records.
3. Between user messages, keep observing only if your tool model lets you do that while preserving the ability to reply. A bounded poll with timeouts is fine. A helper process is fine only if it is local to this transcription directory, has a clear pid/output path, and does not become the only source of transcript truth.
4. If continuous observation would block interaction, do not force it. Wait for the next user turn, then rescan from saved offsets before answering.

Debounce records so you act on natural pauses: flush when 3 seconds pass with no new arrivals or 15 seconds pass since the first buffered record, whichever comes first. During per-turn rescans, flush whatever is already available.

## Handling each batch

Whenever a batch flushes, log every transcription record and interesting lifecycle events as dot-lines:

    - HH:MM:SS <speaker_or_event>: <text-or-category>

Skip noisy audio-started/audio-stopped events unless the user asks for them. If a record addresses you by name, respond conversationally to that turn; still log the rest of the batch. On `recording_stopped`, add a checkpoint summary. On `call_ended`, write a final summary, then stop the watch and end your turn. Summaries should include decisions, action items with owners when named, and open threads. No preamble.

## Wake words

A line addresses you when "OpenCode" or "opencode" appears as a vocative, such as "OpenCode, ..." or "hey OpenCode". Incidental mentions like "OpenCode is installed" are not wakes. When ambiguous, prefer the dot-line log; a missed wake is cheaper than a false one.

## User input

The user can type directly into this terminal to address you or ask a question. Before answering any user message, catch up from the transcript files using your saved offsets, print any new dot-lines, then answer the user's message. After answering, return to the best non-blocking observation strategy available. Do not sit idle waiting for terminal input if your environment can keep observing safely, and do not keep observing in a way that prevents replies.

Catch up on the current transcription directory, then use the best non-blocking observation strategy available. Continue until `call_ended` appears or the user tells you to stop.
PROMPT
} > "${PROMPT_FILE}"

cat > "${COMMAND_FILE}" <<'SCRIPT'
#!/bin/zsh -li
printf '\e]0;Tuple OpenCode Sidekick\a'
clear
echo 'Starting OpenCode sidekick...'
echo

SCRIPT_DIR="${0:A:h}"
PID_FILE="${SCRIPT_DIR}/opencode-sidekick.pid"
PROMPT_FILE="${SCRIPT_DIR}/opencode-sidekick-prompt.md"

echo $$ > "${PID_FILE}"
cd "${SCRIPT_DIR}" || exit 1

if ! command -v opencode >/dev/null 2>&1; then
    echo "OpenCode was not found on your interactive shell PATH."
    echo "Make sure 'opencode' works in a new terminal, then run the trigger again."
    echo
    read '?Press return to close.'
    exit 127
fi

exec opencode . --prompt "$(cat "${PROMPT_FILE}")"
SCRIPT

chmod 0755 "${COMMAND_FILE}"

# --- launch_in_terminal: open the user's preferred terminal directly --------
# Opens the given executable script in the user's terminal. No .command file or
# LaunchServices default handler: it invokes the terminal binary directly (or
# osascript for Terminal/iTerm). The script's `#!/bin/zsh -li` shebang loads the
# user's profile, like a double-clicked .command. Selection order: $PREFERRED_TERM,
# then the first installed of ghostty / iterm / alacritty / terminal.
launch_in_terminal() {
    local script="$1"
    local choice="${PREFERRED_TERM:-}"
    local order=(ghostty iterm alacritty terminal)
    local t

    _term_installed() {
        case "$1" in
        ghostty) [ -x "/Applications/Ghostty.app/Contents/MacOS/ghostty" ] ;;
        iterm) [ -d "/Applications/iTerm.app" ] ;;
        alacritty) [ -x "/Applications/Alacritty.app/Contents/MacOS/alacritty" ] ;;
        terminal) true ;;
        *) return 1 ;;
        esac
    }

    if [ -n "$choice" ] && ! _term_installed "$choice"; then
        echo "launch_in_terminal: PREFERRED_TERM='$choice' not installed; auto-detecting" >&2
        choice=""
    fi
    if [ -z "$choice" ]; then
        for t in "${order[@]}"; do
            if _term_installed "$t"; then choice="$t"; break; fi
        done
    fi
    [ -z "$choice" ] && choice="terminal"

    case "$choice" in
    ghostty) "/Applications/Ghostty.app/Contents/MacOS/ghostty" -e "$script" & ;;
    alacritty) "/Applications/Alacritty.app/Contents/MacOS/alacritty" -e "$script" & ;;
    iterm)
        osascript - "$script" <<'OSA'
on run argv
    set scriptPath to item 1 of argv
    tell application "iTerm"
        activate
        set newWindow to (create window with default profile)
        tell current session of newWindow to write text (quoted form of scriptPath)
    end tell
end run
OSA
        ;;
    terminal | *)
        osascript - "$script" <<'OSA'
on run argv
    set scriptPath to item 1 of argv
    tell application "Terminal"
        activate
        do script (quoted form of scriptPath)
    end tell
end run
OSA
        ;;
    esac
}

if [ "${OPEN_IN_OPENCODE_DRY_RUN:-}" = "1" ]; then
    echo "open-in-opencode: dry run generated ${COMMAND_FILE}"
    exit 0
fi

launch_in_terminal "${COMMAND_FILE}"
