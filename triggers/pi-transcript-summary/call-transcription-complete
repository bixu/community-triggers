#!/usr/bin/env bash
set -euo pipefail

LOG=/tmp/tuple-trigger-debug.log
{
    printf '\n=== %s call-transcription-complete fired (pi-transcript-summary) ===\n' "$(date -u +%FT%TZ)"
    printf 'cwd=%s pid=%s ppid=%s\n' "$(pwd)" "$$" "$PPID"
    printf 'argv: %s\n' "$*"
    printf 'env (filtered):\n'
    env | grep -E '^(HOME|USER|PATH|TUPLE_|CURRENT_USER_)' | sort
} >> "$LOG" 2>&1
trap 'printf "exit status=%s on line %s\n" "$?" "$LINENO" >> "$LOG"' EXIT

exec >>"$LOG" 2>&1

if [ -z "${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY:-}" ]; then
    echo "pi-transcript-summary: TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY was not set" >&2
    exit 1
fi

TRANSCRIPTION_DIR="${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY}"
if [ ! -d "${TRANSCRIPTION_DIR}" ]; then
    echo "pi-transcript-summary: transcription directory does not exist: ${TRANSCRIPTION_DIR}" >&2
    exit 1
fi

SESSION_DIR="$(basename "${TRANSCRIPTION_DIR}")"
PARENT_DIR="$(dirname "${TRANSCRIPTION_DIR}")"
PARENT_NAME="$(basename "${PARENT_DIR}")"
if [[ "${SESSION_DIR}" == *"@"* ]]; then
    CALL_ID="${SESSION_DIR##*@}"
elif [[ "${PARENT_NAME}" =~ ^[0-9A-Fa-f-]{8,}$ ]]; then
    CALL_ID="${PARENT_NAME}"
else
    CALL_ID="${SESSION_DIR}"
fi

PID_FILE="${TRANSCRIPTION_DIR}/pi-summary.pid"
PROMPT_FILE="${TRANSCRIPTION_DIR}/pi-summary-prompt.md"
COMMAND_FILE="${TRANSCRIPTION_DIR}/summarize-in-pi.command"

if [ -f "${PID_FILE}" ] && kill -0 "$(cat "${PID_FILE}" 2>/dev/null)" 2>/dev/null; then
    echo "pi-transcript-summary: Pi summary already running for ${TRANSCRIPTION_DIR}"
    exit 0
fi

{
    cat <<'PROMPT'
You are summarizing a completed Tuple pair-programming transcription, running inside Pi. Your working directory is the Tuple transcription directory opened by this trigger.

PROMPT
    printf 'The trigger fired for:\n\n'
    printf -- '- Transcription directory: %s\n' "${TRANSCRIPTION_DIR}"
    printf -- '- Session directory name: %s\n' "${SESSION_DIR}"
    printf -- '- Inferred call id: %s\n' "${CALL_ID}"
    cat <<'PROMPT'

The current directory should contain `events.jsonl` and `transcriptions.jsonl`, one JSON record per line. Other call participants do not see your output; you interact only with the user at this terminal.

## Goal

Read the transcript artifacts, then immediately produce a tight, useful call summary. This is a completed-transcription trigger, not a live sidekick trigger: do not start a file watcher or write a monitoring extension.

## File schemas

| File | Fields | Notes |
| --- | --- | --- |
| `events.jsonl` | `category, message, time, user?` | Categories commonly include `recording_started`, `recording_stopped`, `user_joined`, `user_left`, `user_audio_started`, `user_audio_stopped`, and `call_ended`. |
| `transcriptions.jsonl` | `start, end, text, user_id` | Resolve `user_id` to a name from `user_joined` events when available. |

If a field looks unfamiliar, inspect a few records and adapt rather than assuming.

## What to read

Start with the current directory's `events.jsonl` and `transcriptions.jsonl`. If the parent directory contains sibling transcription directories whose names end with the inferred call id from the trigger header, inspect those too and include them only when they are clearly part of the same call. Keep the current directory as the primary source.

Build a speaker map from `user_joined` events. Ignore noisy `user_audio_started` and `user_audio_stopped` events unless they matter for interpreting the transcript. Use timestamps when they help anchor decisions, action items, or follow-up questions.

## Output

Produce the summary first, without preamble. Use this shape:

## Summary

2-4 bullets covering the main outcome of the conversation.

## Decisions

Bullets for concrete decisions. Omit this section if there were none.

## Action items

Bullets with owner names when stated. Omit this section if there were none.

## Open questions

Bullets for unresolved questions or follow-ups. Omit this section if there were none.

## Notable context

Only include details that would help the user remember the call later. Omit this section if there is nothing useful.

If the transcript is empty or too sparse to summarize, say that plainly and list which files you found.

## After the summary

Stay available for follow-up questions in this Pi session. When the user asks a question, answer from the transcript files first. Cite speaker names and timestamps when useful. If the user asks for a different format, transform the same transcript-backed facts rather than inventing missing context.
PROMPT
} > "${PROMPT_FILE}"

cat > "${COMMAND_FILE}" <<'SCRIPT'
#!/bin/zsh -li
printf '\e]0;Tuple Transcript Summary\a'
clear
echo 'Starting Pi transcript summary...'
echo

SCRIPT_DIR="${0:A:h}"
PID_FILE="${SCRIPT_DIR}/pi-summary.pid"
PROMPT_FILE="${SCRIPT_DIR}/pi-summary-prompt.md"

echo $$ > "${PID_FILE}"
cd "${SCRIPT_DIR}" || exit 1

if ! command -v pi >/dev/null 2>&1; then
    echo "Pi was not found on your interactive shell PATH."
    echo "Make sure 'pi' works in a new terminal, then run the trigger again."
    echo
    read '?Press return to close.'
    exit 127
fi

exec pi "$(cat "${PROMPT_FILE}")"
SCRIPT

chmod 0755 "${COMMAND_FILE}"

if [ "${PI_TRANSCRIPT_SUMMARY_DRY_RUN:-}" = "1" ]; then
    echo "pi-transcript-summary: dry run generated ${COMMAND_FILE}"
    exit 0
fi

/usr/bin/open "${COMMAND_FILE}" &
