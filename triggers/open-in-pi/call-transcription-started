#!/usr/bin/env bash
set -euo pipefail

LOG=/tmp/tuple-trigger-debug.log
{
    printf '\n=== %s call-transcription-started fired (open-in-pi) ===\n' "$(date -u +%FT%TZ)"
    printf 'cwd=%s pid=%s ppid=%s\n' "$(pwd)" "$$" "$PPID"
    printf 'argv: %s\n' "$*"
    printf 'env (filtered):\n'
    env | grep -E '^(HOME|USER|PATH|TUPLE_|CURRENT_USER_)' | sort
} >> "$LOG" 2>&1
trap 'printf "exit status=%s on line %s\n" "$?" "$LINENO" >> "$LOG"' EXIT

exec >>"$LOG" 2>&1

if [ -z "${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY:-}" ]; then
    echo "open-in-pi: TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY was not set" >&2
    exit 1
fi

TRANSCRIPTION_DIR="${TUPLE_TRIGGER_CALL_ARTIFACTS_DIRECTORY}"
if [ ! -d "${TRANSCRIPTION_DIR}" ]; then
    echo "open-in-pi: transcription directory does not exist: ${TRANSCRIPTION_DIR}" >&2
    exit 1
fi

SESSION_DIR="$(basename "${TRANSCRIPTION_DIR}")"
PARENT_DIR="$(dirname "${TRANSCRIPTION_DIR}")"
PARENT_NAME="$(basename "${PARENT_DIR}")"
if [[ "${SESSION_DIR}" == *"@"* ]]; then
    CALL_ID="${SESSION_DIR##*@}"
elif [[ "${PARENT_NAME}" =~ ^[0-9A-Fa-f-]{8,}$ ]]; then
    CALL_ID="${PARENT_NAME}"
else
    CALL_ID="${SESSION_DIR}"
fi

PID_FILE="${TRANSCRIPTION_DIR}/pi-sidekick.pid"
PROMPT_FILE="${TRANSCRIPTION_DIR}/pi-sidekick-prompt.md"
COMMAND_FILE="${TRANSCRIPTION_DIR}/open-in-pi.command"

if [ -f "${PID_FILE}" ] && kill -0 "$(cat "${PID_FILE}" 2>/dev/null)" 2>/dev/null; then
    echo "open-in-pi: Pi sidekick already running for ${TRANSCRIPTION_DIR}"
    exit 0
fi

# Ship the call-watcher extension into the transcription directory so Pi loads it
# automatically at startup — no /reload, no self-authoring. Pi auto-discovers
# `.pi/extensions/*.ts` from its working directory, which is this directory.
TRIGGER_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
EXTENSION_SRC="${TRIGGER_DIR}/tuple-call-watch.ts"
EXTENSION_DIR="${TRANSCRIPTION_DIR}/.pi/extensions"
mkdir -p "${EXTENSION_DIR}"
if [ -f "${EXTENSION_SRC}" ]; then
    cp "${EXTENSION_SRC}" "${EXTENSION_DIR}/tuple-call-watch.ts"
    printf '{ "artifactsDir": "%s", "callId": "%s" }\n' "${TRANSCRIPTION_DIR}" "${CALL_ID}" \
        > "${EXTENSION_DIR}/tuple-call-watch.config.json"
else
    echo "open-in-pi: shipped extension not found at ${EXTENSION_SRC}; Pi will read transcript files directly" >&2
fi

{
    cat <<'PROMPT'
You are a real-time companion on a live Tuple pair-programming call, running inside Pi. Your working directory is the current Tuple transcription directory opened by this trigger.

PROMPT
    printf 'The trigger fired for:\n\n'
    printf -- '- Transcription directory: %s\n' "${TRANSCRIPTION_DIR}"
    printf -- '- Session directory name: %s\n' "${SESSION_DIR}"
    printf -- '- Inferred call id: %s\n' "${CALL_ID}"
    cat <<'PROMPT'

Other call participants do not see your output; you interact only with the user at this terminal.

## Your watcher is already running

A watcher extension (`tuple-call-watch`) shipped with this trigger and loaded automatically when you started — you do not need to set anything up, write an extension, or run `/reload`. It is doing two things for you right now:

1. **Showing the call to the user live.** As new transcript lines and lifecycle events arrive, it posts them to the TUI as notifications — formatted as `- HH:MM:SS speaker: text`, with speaker names already resolved — so the user sees the conversation flow even while you sit idle. You do not need to echo or re-log these lines yourself.
2. **Keeping you caught up.** At the start of every one of your turns it injects a `tuple-call-watch` context message containing everything new since you last spoke, including the full backlog from before you started. So whenever you reply — even a turn where the user is just chatting — you already have the whole call in context. It flags any turn whose batch contains a wake word or a `recording_stopped` / `call_ended` event.

The watcher stays armed for the entire session and across every turn, so talking with you never pauses or tears it down. Treat it as a convenience layer, not the source of truth: `transcriptions.jsonl` and `events.jsonl` in this directory are authoritative, and if the watcher ever seems stalled (the user says lines are missing and no `tuple-call-watch` context is arriving) just read those files yourself. Their schema:

| File | Fields | Notes |
| --- | --- | --- |
| `events.jsonl` | `category, message, time, user?` | Categories include `recording_started`, `recording_stopped`, `user_joined`, `user_left`, and `call_ended`. |
| `transcriptions.jsonl` | `start, end, text, user_id` | `user_id` resolves to a name from `user_joined` events. |

## How to behave

The watcher handles the running log, so your job is to react, not narrate:

- **When a line addresses you**, respond conversationally. A line addresses you when "Pi" appears as a vocative — "Pi, ..." or "hey Pi". Incidental uses like "the value of pi" or "a slice of pie" are not wakes, and a bare "Pi" with no request attached is not a wake. "Pi" is short and easily misheard, so when in doubt stay quiet; a missed wake is cheaper than a false one. The watcher cannot start a turn for you, so if you were addressed while idle you will see it the moment the user next hands you a turn — answer it then.
- **When the user talks to you** — asking what was just said, for a summary so far, or to talk through the work — answer from the call context you already have. This never stops the watch; after you answer, the watcher simply keeps going.
- **On `recording_stopped`**, add a short checkpoint summary. **On `call_ended`**, write a final summary and end your turn. Summaries cover decisions, action items with owners when named, and open threads. No preamble.

Start by giving the user a one-line confirmation that you are watching the call and caught up, then wait. Continue until `call_ended` arrives or the user tells you to stop.
PROMPT
} > "${PROMPT_FILE}"

cat > "${COMMAND_FILE}" <<'SCRIPT'
#!/bin/zsh -li
printf '\e]0;Tuple Pi Sidekick\a'
clear
echo 'Starting Pi sidekick...'
echo

SCRIPT_DIR="${0:A:h}"
PID_FILE="${SCRIPT_DIR}/pi-sidekick.pid"
PROMPT_FILE="${SCRIPT_DIR}/pi-sidekick-prompt.md"

echo $$ > "${PID_FILE}"
cd "${SCRIPT_DIR}" || exit 1

if ! command -v pi >/dev/null 2>&1; then
    echo "Pi was not found on your interactive shell PATH."
    echo "Make sure 'pi' works in a new terminal, then run the trigger again."
    echo
    read '?Press return to close.'
    exit 127
fi

exec pi "$(cat "${PROMPT_FILE}")"
SCRIPT

chmod 0755 "${COMMAND_FILE}"

if [ "${OPEN_IN_PI_DRY_RUN:-}" = "1" ]; then
    echo "open-in-pi: dry run generated ${COMMAND_FILE}"
    exit 0
fi

/usr/bin/open "${COMMAND_FILE}" &
